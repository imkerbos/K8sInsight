# Production images
BACKEND_IMAGE=ghcr.io/imkerbos/k8sinsight-backend:latest
FRONTEND_IMAGE=ghcr.io/imkerbos/k8sinsight-frontend:latest

# Database (internal postgres service in compose)
DB_USER=k8sinsight
DB_PASSWORD=change-me-strong-password
DB_DBNAME=k8sinsight

# Auth
JWT_SECRET=change-me-super-secret
DEFAULT_ADMIN_PASSWORD=change-me-admin-password

# Ports
BACKEND_PORT=10080
FRONTEND_PORT=3500
