FROM golang:1.25-alpine AS builder

WORKDIR /build
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -o k8sinsight ./cmd/k8sinsight

FROM alpine:3.21
RUN apk add --no-cache ca-certificates tzdata
WORKDIR /app
COPY --from=builder /build/k8sinsight .
COPY configs/config.yaml configs/config.yaml

EXPOSE 10080
ENTRYPOINT ["./k8sinsight"]
